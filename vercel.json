{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/campus/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/campus",
      "destination": "/index.html"
    },
    {
      "source": "/campus/:path*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/campus",
      "permanent": false
    }
  ]
}
